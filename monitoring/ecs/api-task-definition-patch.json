{
  "_description": "기존 taghere-dev-api 태스크 정의에 Promtail 사이드카를 추가하기 위한 패치 파일",
  "_usage": "buildspec 또는 수동 배포 시 기존 태스크 정의의 containerDefinitions에 아래 컨테이너를 추가하고, volumes에 shared-logs 볼륨을 추가합니다.",

  "additionalContainerDefinition": {
    "name": "promtail",
    "image": "grafana/promtail:3.4.2",
    "essential": false,
    "cpu": 64,
    "memory": 128,
    "mountPoints": [
      {
        "sourceVolume": "shared-logs",
        "containerPath": "/var/log/app",
        "readOnly": true
      },
      {
        "sourceVolume": "promtail-config",
        "containerPath": "/etc/promtail",
        "readOnly": true
      }
    ],
    "command": ["-config.file=/etc/promtail/config.yml"],
    "environment": [
      { "name": "ENVIRONMENT", "value": "dev" },
      { "name": "LOKI_URL", "value": "http://loki.taghere-dev:3100" }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/taghere-dev-api",
        "awslogs-region": "ap-northeast-2",
        "awslogs-stream-prefix": "promtail"
      }
    }
  },

  "additionalVolumes": [
    {
      "name": "shared-logs",
      "host": {}
    },
    {
      "name": "promtail-config",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/promtail/config"
      }
    }
  ],

  "_apiContainerChanges": {
    "_note": "API 컨테이너(taghere-api)에 다음 mountPoint를 추가해야 합니다",
    "additionalMountPoint": {
      "sourceVolume": "shared-logs",
      "containerPath": "/var/log/app",
      "readOnly": false
    },
    "_loggingNote": "Spring Boot 로그를 /var/log/app 경로로도 출력하려면 logback-spring.xml에 FILE appender를 추가해야 합니다. stdout 로그만 수집하는 경우에는 Docker 로그 드라이버를 통해 Promtail이 수집하므로 이 변경은 불필요합니다."
  }
}
