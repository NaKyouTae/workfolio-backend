{
  "family": "taghere-dev-monitoring",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "prometheus",
      "image": "prom/prometheus:latest",
      "essential": true,
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 9090,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "prometheus-config",
          "containerPath": "/etc/prometheus",
          "readOnly": true
        },
        {
          "sourceVolume": "prometheus-data",
          "containerPath": "/prometheus",
          "readOnly": false
        }
      ],
      "command": [
        "--config.file=/etc/prometheus/prometheus.yml",
        "--storage.tsdb.path=/prometheus",
        "--storage.tsdb.retention.time=15d",
        "--web.enable-lifecycle"
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:9090/-/healthy || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taghere-dev-monitoring",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "prometheus"
        }
      }
    },
    {
      "name": "grafana",
      "image": "grafana/grafana:latest",
      "essential": true,
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "grafana-provisioning",
          "containerPath": "/etc/grafana/provisioning",
          "readOnly": true
        },
        {
          "sourceVolume": "grafana-dashboards",
          "containerPath": "/var/lib/grafana/dashboards",
          "readOnly": true
        },
        {
          "sourceVolume": "grafana-data",
          "containerPath": "/var/lib/grafana",
          "readOnly": false
        }
      ],
      "environment": [
        { "name": "GF_SECURITY_ADMIN_USER", "value": "admin" },
        { "name": "GF_USERS_ALLOW_SIGN_UP", "value": "false" },
        { "name": "GF_DATE_FORMATS_DEFAULT_TIMEZONE", "value": "Asia/Seoul" }
      ],
      "secrets": [
        {
          "name": "GF_SECURITY_ADMIN_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2::secret:taghere/dev/monitoring/secret:GF_ADMIN_PASSWORD::"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taghere-dev-monitoring",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "grafana"
        }
      }
    },
    {
      "name": "loki",
      "image": "grafana/loki:3.4.2",
      "essential": true,
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 3100,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "loki-config",
          "containerPath": "/etc/loki",
          "readOnly": true
        },
        {
          "sourceVolume": "loki-data",
          "containerPath": "/loki",
          "readOnly": false
        }
      ],
      "command": ["-config.file=/etc/loki/config.yml"],
      "environment": [
        { "name": "S3_BUCKET", "value": "taghere-v2" },
        { "name": "S3_PREFIX", "value": "monitoring/logs" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3100/ready || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taghere-dev-monitoring",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "loki"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "prometheus-config",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/prometheus/config"
      }
    },
    {
      "name": "prometheus-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/prometheus/data"
      }
    },
    {
      "name": "grafana-provisioning",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/grafana/provisioning"
      }
    },
    {
      "name": "grafana-dashboards",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/grafana/dashboards"
      }
    },
    {
      "name": "grafana-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/grafana/data"
      }
    },
    {
      "name": "loki-config",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/loki/config"
      }
    },
    {
      "name": "loki-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
        "rootDirectory": "/monitoring/loki/data"
      }
    }
  ]
}
