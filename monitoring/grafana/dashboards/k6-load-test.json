        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_duration_p90",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_duration_p99",
          "legendFormat": "p99",
          "refId": "D"
        }
