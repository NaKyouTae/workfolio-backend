        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_connecting_avg",
          "legendFormat": "connecting",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_waiting_avg",
          "legendFormat": "waiting (TTFB)",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_sending_avg",
          "legendFormat": "sending",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "k6_http_req_receiving_avg",
          "legendFormat": "receiving",
          "refId": "E"
        }
      ]
