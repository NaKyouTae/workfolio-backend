{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Total Errors (선택 기간)",
      "targets": [
        {
          "expr": "count_over_time({container=~\"$container\"} |= \"ERROR\" [$__range])",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Total Warnings (선택 기간)",
      "targets": [
        {
          "expr": "count_over_time({container=~\"$container\"} |= \"WARN\" [$__range])",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Total Logs (선택 기간)",
      "targets": [
        {
          "expr": "count_over_time({container=~\"$container\"} [$__range])",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "title": "Log Volume by Level",
      "targets": [
        {
          "expr": "sum by(level) (count_over_time({container=~\"$container\"} | regexp `(?P<level>ERROR|WARN|INFO|DEBUG)` [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Application Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "id": 10,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "All Logs",
      "targets": [
        {
          "expr": "{container=~\"$container\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Error Tracking",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "id": 20,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "Error Logs Only",
      "targets": [
        {
          "expr": "{container=~\"$container\"} |= \"ERROR\" != \"actuator\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 21,
      "title": "Error Rate (per minute)",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$container\"} |= \"ERROR\" [1m]))",
          "legendFormat": "Errors / min",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 22,
      "title": "Warning Rate (per minute)",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$container\"} |= \"WARN\" [1m]))",
          "legendFormat": "Warnings / min",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "title": "Exception Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "id": 30,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "Exceptions (Stack Traces)",
      "targets": [
        {
          "expr": "{container=~\"$container\"} |~ \"(?i)(exception|stacktrace|caused by)\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 104,
      "title": "Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 51 },
      "id": 40,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "Slow Queries",
      "targets": [
        {
          "expr": "{container=~\"$container\"} |~ \"(?i)(slow.?query|long.?running|timeout|timed.?out)\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 51 },
      "id": 41,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "Connection Pool Issues",
      "targets": [
        {
          "expr": "{container=~\"$container\"} |~ \"(?i)(hikari|connection.?pool|connection is not available|connection.?leak)\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "tags": ["loki", "logs", "workfolio"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "definition": "label_values(container)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "container",
        "options": [],
        "query": "label_values(container)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox",
        "label": "Search keyword"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "Workfolio API - Logs (Loki)",
  "uid": "workfolio-loki-logs",
  "version": 1
}
